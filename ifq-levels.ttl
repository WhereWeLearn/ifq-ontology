    skos:definition "Approximate early primary entry progression stage."@en ;
    ifq:ifqLevelNumber 3 ;
    ifq:broadStage "Primary" ;
    ifq:alignedWithISCED "1" ;
    ifq:typicalAge 6 ;
    ifq:follows ifq:IFQ_02 ;
    ifq:precedes ifq:IFQ_04 .

ifq:IFQ_04
    a ifq:IFQLevel, skos:Concept ;
    skos:prefLabel "IFQ Level 4"@en ;
    skos:notation "4" ;
