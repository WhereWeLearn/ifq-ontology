    skos:definition "Approximate short-cycle tertiary or advanced diploma progression stage."@en ;
    ifq:ifqLevelNumber 17 ;
    ifq:broadStage "Short-cycle Tertiary" ;
    ifq:alignedWithISCED "5" ;
    ifq:typicalAge 18 ;
    ifq:follows ifq:IFQ_16 ;
    ifq:precedes ifq:IFQ_18 .

