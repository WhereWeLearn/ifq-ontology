    ifq:ifqLevelNumber 4 ;
    ifq:broadStage "Primary" ;
    ifq:alignedWithISCED "1" ;
    ifq:typicalAge 7 ;
    ifq:follows ifq:IFQ_03 ;
    ifq:precedes ifq:IFQ_05 .

ifq:IFQ_05
    a ifq:IFQLevel, skos:Concept ;
    skos:prefLabel "IFQ Level 5"@en ;
    skos:notation "5" ;
