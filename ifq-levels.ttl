    skos:inScheme ifq:IFQConceptScheme ;
    skos:definition "Approximate early undergraduate progression stage."@en ;
    ifq:ifqLevelNumber 18 ;
    ifq:broadStage "Undergraduate" ;
    ifq:alignedWithISCED "6" ;
