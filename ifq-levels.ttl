    a ifq:IFQLevel, skos:Concept ;
    skos:prefLabel "IFQ Level 11"@en ;
    skos:notation "11" ;
    skos:inScheme ifq:IFQConceptScheme ;
    skos:definition "Approximate lower secondary progression stage."@en ;
    ifq:ifqLevelNumber 11 ;
    ifq:broadStage "Lower Secondary" ;
    ifq:alignedWithISCED "2" ;
