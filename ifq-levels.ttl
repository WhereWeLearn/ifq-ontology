ifq:LevelsOntology
    a owl:Ontology ;
    dcterms:title "IFQ Levels"@en ;
    dcterms:description "The 22-level SKOS concept scheme for the International Framework of Qualifications."@en ;
    dcterms:creator "WhereWeLearn"@en ;
    dcterms:issued "2026-05-11"^^xsd:date ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:rights "Copyright 2026 WhereWeLearn. Licensed under CC BY 4.0 — https://creativecommons.org/licenses/by/4.0/"@en ;
    owl:versionInfo "1.0.0" .

ifq:IFQConceptScheme
    a skos:ConceptScheme ;
    skos:prefLabel "International Framework of Qualifications Levels"@en ;
    skos:definition "A 22-level sparse international educational progression concept scheme."@en .

ifq:IFQ_01
    a ifq:IFQLevel, skos:Concept ;
    skos:prefLabel "IFQ Level 1"@en ;
    skos:notation "1" ;
    skos:inScheme ifq:IFQConceptScheme ;
    skos:definition "Approximate early childhood or pre-primary progression stage."@en ;
    ifq:ifqLevelNumber 1 ;
    ifq:broadStage "Early Years" ;
    ifq:alignedWithISCED "0" ;
    ifq:typicalAge 4 ;
    ifq:precedes ifq:IFQ_02 .

ifq:IFQ_02
    a ifq:IFQLevel, skos:Concept ;
    skos:prefLabel "IFQ Level 2"@en ;
    skos:notation "2" ;
    skos:inScheme ifq:IFQConceptScheme ;
    skos:definition "Approximate transition from early years toward primary progression."@en ;
    ifq:ifqLevelNumber 2 ;
    ifq:broadStage "Primary" ;
    ifq:alignedWithISCED "0/1" ;
    ifq:typicalAge 5 ;
    ifq:follows ifq:IFQ_01 ;
    ifq:precedes ifq:IFQ_03 .

ifq:IFQ_03
    a ifq:IFQLevel, skos:Concept ;
    skos:prefLabel "IFQ Level 3"@en ;
    skos:notation "3" ;
