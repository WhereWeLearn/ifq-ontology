    skos:definition "Approximate upper secondary completion or university-entry progression stage."@en ;
    ifq:ifqLevelNumber 15 ;
    ifq:broadStage "Upper Secondary" ;
    ifq:alignedWithISCED "3" ;
    ifq:typicalAge 18 ;
    ifq:follows ifq:IFQ_14 ;
    ifq:precedes ifq:IFQ_16 .

ifq:IFQ_16
    a ifq:IFQLevel, skos:Concept ;
    skos:prefLabel "IFQ Level 16"@en ;
