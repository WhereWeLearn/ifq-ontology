map:Stage_AE-KG1
    a ifq:EducationStage ;
    rdfs:label "KG1"@en ;
    ifq:belongsToSystem map:System_AE ;
    ifq:mapsToIFQLevel ifq:IFQ_01 ;
    ifq:localStageName "KG1" ;
    ifq:broadStage "Early Years" ;
    ifq:alignedWithISCED "0" ;
    ifq:typicalAge 4 ;
    ifq:typicalMinAge 4 ;
    ifq:typicalMaxAge 4 ;
    ifq:progressionType "Pre-primary" ;
    ifq:confidence "Medium" ;
    ifq:notes "UAE MoE kindergarten stage; Gulf private/international systems may vary."@en .

map:Assertion_AE-KG1
    a ifq:MappingAssertion ;
    rdfs:label "Mapping assertion for KG1"@en ;
    ifq:assertsStage map:Stage_AE-KG1 ;
    ifq:assertsIFQLevel ifq:IFQ_01 ;
    ifq:confidence "Medium" ;
    ifq:notes "UAE MoE kindergarten stage; Gulf private/international systems may vary."@en ;
    ifq:hasSource map:Source_309 .

